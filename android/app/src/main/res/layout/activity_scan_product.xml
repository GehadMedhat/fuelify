<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1C1E">

    <!-- Camera preview fills the whole screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
    </androidx.camera.view.PreviewView>

    <!-- Dark overlay top -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#CC1C1C1E"/>

    <!-- Dark overlay bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_gravity="bottom"
        android:background="#CC1C1C1E"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="56dp">

        <ImageButton
            android:id="@+id/btnScanBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            />

        <TextView
            android:text="Scan Product"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Position the barcode within the frame"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Scan frame overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <!-- The scan frame view (custom drawn corners) -->
        <com.example.fuelify.views.ScanFrameView
            android:id="@+id/scanFrame"
            android:layout_width="260dp"
            android:layout_height="260dp"/>
    </LinearLayout>

    <!-- Bottom controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="48dp"
        android:paddingTop="20dp">

        <!-- Scanning indicator -->
        <TextView
            android:id="@+id/tvScanStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍  Scanning..."
            android:textColor="#F97316"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"
            android:visibility="gone"/>

        <!-- Flash toggle -->
        <LinearLayout
            android:id="@+id/btnToggleFlash"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_recommended_card"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tvFlashIcon"
                android:text="⚡"
                android:textSize="24sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView
            android:text="Flash"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:layout_marginTop="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</FrameLayout>
