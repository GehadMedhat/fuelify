<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F9FAFB" android:orientation="vertical">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#FFFFFF" android:paddingHorizontal="20dp"
        android:paddingTop="48dp" android:paddingBottom="14dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:elevation="4dp">
        <ImageButton android:id="@+id/btnDoctorCaseBack" android:layout_width="40dp"
            android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/button_arrow" android:scaleType="fitCenter" android:layout_marginEnd="10dp"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvCasePatientHeader" android:textColor="#000000"
                android:textSize="18sp" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Patient Case" android:textColor="#737373" android:textSize="12sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <TextView android:id="@+id/tvDoctorCaseStatus" android:text="Open"
            android:textColor="#F97316" android:textSize="11sp" android:textStyle="bold"
            android:background="#FFF7ED" android:paddingHorizontal="10dp" android:paddingVertical="5dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <ScrollView android:id="@+id/scrollDoctorCase"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingBottom="16dp">

            <!-- Case overview -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="#FFFFFF" android:padding="20dp"
                android:orientation="vertical" android:layout_marginBottom="8dp">

                <TextView android:id="@+id/tvDoctorCaseCondition" android:textColor="#000000"
                    android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvDoctorCaseArea" android:textColor="#737373"
                    android:textSize="13sp" android:layout_marginBottom="14dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <TextView android:text="SYMPTOMS" android:textColor="#9CA3AF"
                    android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="6dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvDoctorCaseSymptoms" android:textColor="#374151"
                    android:textSize="13sp" android:background="#F9FAFB" android:padding="12dp"
                    android:lineSpacingExtra="3dp" android:layout_marginBottom="12dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>

                <TextView android:id="@+id/tvDoctorCaseLimitations" android:textColor="#374151"
                    android:textSize="13sp" android:background="#F9FAFB" android:padding="12dp"
                    android:visibility="gone"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Already responded banner -->
            <LinearLayout android:id="@+id/layoutAlreadyResponded"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="#DCFCE7" android:paddingHorizontal="20dp"
                android:paddingVertical="12dp" android:orientation="horizontal"
                android:gravity="center_vertical" android:layout_marginBottom="8dp"
                android:visibility="gone">
                <TextView android:text="✓ " android:textColor="#166534" android:textSize="16sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="You have already responded to this case. +25 EGP credited to your wallet."
                    android:textColor="#166534" android:textSize="13sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Conversation -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="#FFFFFF" android:padding="20dp"
                android:orientation="vertical" android:layout_marginBottom="8dp">

                <TextView android:text="Conversation" android:textColor="#000000"
                    android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="16dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <LinearLayout android:id="@+id/containerDoctorMessages"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

            <!-- Response form -->
            <LinearLayout android:id="@+id/layoutDoctorRespond"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="#FFFFFF" android:padding="20dp"
                android:orientation="vertical">

                <TextView android:text="Your Response" android:textColor="#000000"
                    android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <!-- Quick reply chips -->
                <TextView android:text="Quick inserts:" android:textColor="#9CA3AF"
                    android:textSize="11sp" android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:scrollbars="none" android:layout_marginBottom="12dp">
                    <LinearLayout android:id="@+id/containerQuickReplies"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal"/>
                </HorizontalScrollView>

                <EditText android:id="@+id/etDoctorResponse" android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:hint="Write your personalized response to the patient..."
                    android:background="@drawable/bg_recommended_card" android:padding="14dp"
                    android:textSize="13sp" android:inputType="textMultiLine"
                    android:textColor="#111827" android:textColorHint="#9CA3AF"
                    android:gravity="top"
                    android:layout_marginBottom="8dp"/>

                <TextView android:text="Your response will be visible to the patient immediately. +25 EGP will be credited to your wallet."
                    android:textColor="#9CA3AF" android:textSize="11sp"
                    android:layout_marginBottom="14dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <LinearLayout android:id="@+id/btnDoctorSendResponse" android:layout_width="match_parent"
                    android:layout_height="52dp" android:background="@drawable/orange_rectangle"
                    android:gravity="center" android:clickable="true" android:focusable="true">
                    <TextView android:text="✓  Send Response (+25 EGP)" android:textColor="#92400E"
                        android:textSize="15sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
