<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingBottom="24dp">

            <!-- Header -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingTop="52dp" android:layout_marginBottom="4dp">
                <ImageButton android:id="@+id/btnHealthReportBack" android:layout_width="40dp"
                    android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/button_arrow"
                    android:scaleType="fitCenter" android:layout_marginEnd="10dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="Export Health Report" android:textColor="#000000"
                        android:textSize="20sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Share your health summary with your doctor"
                        android:textColor="#737373" android:textSize="12sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Privacy Settings -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_recommended_card" android:padding="16dp"
                android:layout_marginTop="24dp" android:layout_marginBottom="16dp" android:orientation="vertical">
                <TextView android:text="Privacy Settings" android:textColor="#000000" android:textSize="16sp"
                    android:textStyle="bold" android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="Hide Weight Information" android:textColor="#000000" android:textSize="14sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Remove weight data from report" android:textColor="#737373" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switchHideWeight" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="Hide Calorie Information" android:textColor="#000000" android:textSize="14sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Remove calorie data from report" android:textColor="#737373" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switchHideCalories" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Report Preview -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_recommended_card" android:padding="16dp"
                android:layout_marginBottom="16dp" android:orientation="vertical">
                <TextView android:text="Report Preview" android:textColor="#000000" android:textSize="16sp"
                    android:textStyle="bold" android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="#F9FAFB" android:padding="12dp" android:layout_marginBottom="10dp" android:orientation="vertical">
                    <TextView android:text="Medical Conditions" android:textColor="#000000" android:textSize="13sp"
                        android:textStyle="bold" android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <LinearLayout android:id="@+id/containerReportConditions" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="horizontal"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="#F9FAFB" android:padding="12dp" android:layout_marginBottom="10dp" android:orientation="vertical">
                    <TextView android:text="Weekly Plan Summary" android:textColor="#000000" android:textSize="13sp"
                        android:textStyle="bold" android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:text="Workouts Completed" android:textColor="#737373" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/tvReportWorkouts" android:text="0/15" android:textColor="#C3E66E" android:textSize="22sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:text="Meals Logged" android:textColor="#737373" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/tvReportMeals" android:text="0/21" android:textColor="#C3E66E" android:textSize="22sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="10dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:text="Total This Week" android:textColor="#737373" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/tvReportTotalCal" android:text="—" android:textColor="#374151" android:textSize="14sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:text="Daily Average" android:textColor="#737373" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/tvReportAvgCal" android:text="—" android:textColor="#374151" android:textSize="14sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="#F9FAFB" android:padding="12dp" android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:text="7-Day Calorie Progress" android:textColor="#000000" android:textSize="13sp"
                            android:textStyle="bold" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                        <TextView android:text="🟩 workout day" android:textColor="#9CA3AF" android:textSize="10sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <LinearLayout android:id="@+id/containerProgressBars" android:layout_width="match_parent"
                        android:layout_height="130dp" android:orientation="horizontal" android:gravity="bottom"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Lab Results -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_recommended_card" android:padding="16dp"
                android:layout_marginBottom="16dp" android:orientation="vertical">
                <TextView android:text="Lab Results Analysis" android:textColor="#000000" android:textSize="16sp"
                    android:textStyle="bold" android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Enter your lab values for personalized recommendations"
                    android:textColor="#737373" android:textSize="12sp" android:layout_marginBottom="14dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:text="HbA1c (%)" android:textColor="#374151" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etLabHba1c" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 5.8"     android:textColor="#111827" android:textColorHint="#9CA3AF" android:inputType="numberDecimal" android:background="@drawable/bg_recommended_card" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="Cholesterol (mg/dL)" android:textColor="#374151" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etLabCholesterol" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 195"     android:textColor="#111827" android:textColorHint="#9CA3AF" android:inputType="numberDecimal" android:background="@drawable/bg_recommended_card" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:text="LDL (mg/dL)" android:textColor="#374151" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etLabLdl" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 110"     android:textColor="#111827" android:textColorHint="#9CA3AF" android:inputType="numberDecimal" android:background="@drawable/bg_recommended_card" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="HDL (mg/dL)" android:textColor="#374151" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etLabHdl" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 55"     android:textColor="#111827" android:textColorHint="#9CA3AF" android:inputType="numberDecimal" android:background="@drawable/bg_recommended_card" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:text="Fasting Glucose (mg/dL)" android:textColor="#374151" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etLabGlucose" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 92" android:textColor="#111827" android:textColorHint="#9CA3AF" android:inputType="numberDecimal" android:background="@drawable/bg_recommended_card" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="TSH (mIU/L)" android:textColor="#374151" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etLabTsh" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 2.5"     android:textColor="#111827" android:textColorHint="#9CA3AF" android:inputType="numberDecimal" android:background="@drawable/bg_recommended_card" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:text="BP Systolic (mmHg)" android:textColor="#374151" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etLabBpSys" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 120"     android:textColor="#111827" android:textColorHint="#9CA3AF" android:inputType="number" android:background="@drawable/bg_recommended_card" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="BP Diastolic (mmHg)" android:textColor="#374151" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <EditText android:id="@+id/etLabBpDia" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 80" android:textColor="#111827" android:textColorHint="#9CA3AF" android:inputType="number" android:background="@drawable/bg_recommended_card" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:id="@+id/btnAnalyzeLabs" android:layout_width="match_parent"
                    android:layout_height="48dp" android:background="@drawable/orange_rectangle"
                    android:gravity="center" android:clickable="true" android:focusable="true" android:layout_marginBottom="12dp">
                    <TextView android:text="Analyze Lab Results" android:textColor="#000000"
                        android:textSize="14sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView android:id="@+id/tvLabRecommendations" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="#374151" android:textSize="13sp"
                    android:lineSpacingExtra="4dp" android:background="#F0FDF4" android:padding="12dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Share buttons -->
            <LinearLayout android:id="@+id/btnDownloadPDF" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/orange_rectangle"
                android:gravity="center" android:layout_marginBottom="10dp"
                android:clickable="true" android:focusable="true">
                <TextView android:text="⬇  Download PDF" android:textColor="#000000" android:textSize="15sp"
                    android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/btnShareEmail" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/bg_recommended_card"
                android:gravity="center" android:layout_marginBottom="10dp"
                android:clickable="true" android:focusable="true">
                <TextView android:text="✉  Share via Email" android:textColor="#F97316" android:textSize="15sp"
                    android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/btnShareWhatsApp" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/whatsapp_color"
                android:gravity="center" android:layout_marginBottom="16dp"
                android:clickable="true" android:focusable="true">
                <TextView android:text="💬  Share via WhatsApp" android:textColor="#4A6200" android:textSize="15sp"
                    android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="#FFF7ED" android:padding="14dp" android:orientation="horizontal">
                <TextView android:text="🔒  " android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Your report includes all health data from the last 30 days. Medical information is encrypted and HIPAA compliant."
                    android:textColor="#92400E" android:textSize="12sp"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
