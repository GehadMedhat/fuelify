<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_streak_card"
    android:orientation="vertical"
    android:paddingBottom="40dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="#D1D5DB"/>

    <!-- Product name + nutri-score -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvProductName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#171717"
                android:textSize="17sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvProductBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#737373"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Nutri-score badge -->
        <LinearLayout
            android:id="@+id/layoutNutriScore"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNutriScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:singleLine="true"/>

            <TextView
                android:text="Nutri"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Suitability banner -->
    <LinearLayout
        android:id="@+id/layoutSuitability"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="14dp">

        <TextView
            android:id="@+id/tvSuitabilityIcon"
            android:text="✓"
            android:textSize="16sp"
            android:layout_marginEnd="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvSuitabilityText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Macros row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="16dp">

        <!-- Calories -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_recommended_card" android:padding="10dp"
            android:layout_marginEnd="6dp">
            <TextView android:id="@+id/tvScanCalories" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="#171717"
                android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:text="kcal" android:textColor="#737373" android:textSize="10sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Protein -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_recommended_card" android:padding="10dp"
            android:layout_marginEnd="6dp">
            <TextView android:id="@+id/tvScanProtein" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="#171717"
                android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:text="protein" android:textColor="#737373" android:textSize="10sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Carbs -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_recommended_card" android:padding="10dp"
            android:layout_marginEnd="6dp">
            <TextView android:id="@+id/tvScanCarbs" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="#171717"
                android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:text="carbs" android:textColor="#737373" android:textSize="10sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Fat -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_recommended_card" android:padding="10dp">
            <TextView android:id="@+id/tvScanFat" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="#171717"
                android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:text="fat" android:textColor="#737373" android:textSize="10sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Allergens -->
    <LinearLayout
        android:id="@+id/layoutAllergens"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <TextView
            android:text="⚠️  Allergens"
            android:textColor="#374151"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvAllergens"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#EF4444"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Ingredients -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:text="Ingredients"
            android:textColor="#374151"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvIngredients"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#737373"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"
            android:maxLines="4"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Action buttons row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="8dp">

        <!-- Add to Grocery List -->
        <LinearLayout
            android:id="@+id/btnAddToGrocery"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_badge_completed"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:text="🛒  Grocery List"
                android:textColor="#4A6200"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Add to Pantry -->
        <LinearLayout
            android:id="@+id/btnAddToPantry"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_badge_completed"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:text="🥫  Add to Pantry"
                android:textColor="#4A6200"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Scan Again full width -->
    <LinearLayout
        android:id="@+id/btnScanAgain"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/bg_recommended_card"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:text="🔄  Scan Again"
            android:textColor="#374151"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</LinearLayout>
