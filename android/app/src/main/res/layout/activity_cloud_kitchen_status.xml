<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="20dp">

        <ImageButton
            android:id="@+id/btnStatusBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_notif"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Cloud Kitchen Order"
            android:textColor="#111827"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send your meal plan to our partner kitchen"
            android:textColor="#888888"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6"/>

    <!-- Status content — centered -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp">

        <!-- Animated icon container -->
        <FrameLayout
            android:id="@+id/statusIconContainer"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_streak_card">

            <!-- Spinner (preparing state) -->
            <ProgressBar
                android:id="@+id/statusSpinner"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:indeterminateTint="#C3E66E"
                android:visibility="gone"/>

            <!-- Check (delivered state) -->
            <TextView
                android:id="@+id/statusCheckmark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✓"
                android:textColor="#4CAF50"
                android:textSize="42sp"
                android:textStyle="bold"
                android:visibility="gone"/>
        </FrameLayout>

        <TextView
            android:id="@+id/tvStatusTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="Preparing Your Meals"
            android:textColor="#111827"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvStatusSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:text="Our kitchen is working on your order"
            android:textColor="#888888"
            android:textSize="13sp"/>

        <!-- Delivery time card — only shown when delivered -->
        <LinearLayout
            android:id="@+id/cardDeliveryTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_recommended_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Estimated Delivery"
                android:textColor="#888888"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvDeliveryTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today, 6:00 PM - 7:00 PM"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
