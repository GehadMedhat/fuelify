<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_recommended_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <!-- Top row: avatar + name/goal + calories goal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Avatar circle -->
        <LinearLayout
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/light_orange_rectangle"
            android:gravity="center"
            android:layout_marginEnd="12dp">
            <TextView
                android:id="@+id/tvMemberAvatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="J"
                android:textColor="#4A6200"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Name + goal + streak -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvMemberName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#171717"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvMemberRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin"
                    android:textColor="#4A6200"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/orange_rectangle"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvMemberGoal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#737373"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvMemberStreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F97316"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Calories goal -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvMemberCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#171717"
                android:textSize="17sp"
                android:textStyle="bold"/>

            <TextView
                android:text="kcal goal"
                android:textColor="#737373"
                android:textSize="10sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Calories eaten progress bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp">

        <!-- Eaten / Goal label -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="5dp">

            <TextView
                android:id="@+id/tvCaloriesEaten"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#374151"
                android:textSize="11sp"
                android:text="0 eaten today"/>

            <TextView
                android:id="@+id/tvCaloriesRemaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:text="0 remaining"/>
        </LinearLayout>

        <!-- Progress bar track -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="7dp">

            <!-- Background track -->
            <View
                android:layout_width="match_parent"
                android:layout_height="7dp"
                android:background="@drawable/bg_recommended_card"/>

            <!-- Fill -->
            <View
                android:id="@+id/viewCaloriesProgress"
                android:layout_width="0dp"
                android:layout_height="7dp"
                android:background="@drawable/orange_rectangle"/>
        </FrameLayout>
    </LinearLayout>

    <!-- Remove button (admin only) -->
    <TextView
        android:id="@+id/btnRemoveMember"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Remove from family"
        android:textColor="#EF4444"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:layout_marginTop="10dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"/>

</LinearLayout>
