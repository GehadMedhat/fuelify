<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <!-- Scrollable form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="52dp"
                android:paddingBottom="20dp">

                <ImageButton
                    android:id="@+id/btnKitchenBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/button_arrow"
                    android:layout_marginEnd="12dp"/>/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Cloud Kitchen Order"
                    android:textColor="#111827"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Send your meal plan to our partner kitchen"
                    android:textColor="#888888"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginBottom="24dp"/>

            <!-- Choose Plan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"
                android:text="Choose Plan"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <!-- Daily Plan -->
            <LinearLayout
                android:id="@+id/cardDailyPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_recommended_card"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Daily Plan" android:textColor="#111827" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="3 meals/day" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>
                <TextView android:id="@+id/checkDailyPlan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="#C3E66E" android:textSize="18sp" android:textStyle="bold" android:visibility="gone"/>
            </LinearLayout>

            <!-- Weekly Plan -->
            <LinearLayout
                android:id="@+id/cardWeeklyPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_recommended_card"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Weekly Plan" android:textColor="#111827" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="21 meals/week" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>
                <TextView android:id="@+id/checkWeeklyPlan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="#C3E66E" android:textSize="18sp" android:textStyle="bold" android:visibility="gone"/>
            </LinearLayout>

            <!-- Portion Size -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"
                android:text="Portion Size"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <TextView android:id="@+id/btnPortionSmall" android:layout_width="90dp" android:layout_height="44dp" android:layout_marginEnd="10dp" android:background="@drawable/bg_recommended_card" android:gravity="center" android:text="small" android:textColor="#374151" android:textSize="13sp" android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btnPortionRegular" android:layout_width="90dp" android:layout_height="44dp" android:layout_marginEnd="10dp" android:background="@drawable/bg_recommended_card" android:gravity="center" android:text="regular" android:textColor="#374151" android:textSize="13sp" android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btnPortionLarge" android:layout_width="90dp" android:layout_height="44dp" android:background="@drawable/bg_recommended_card" android:gravity="center" android:text="large" android:textColor="#374151" android:textSize="13sp" android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- Spice Level -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"
                android:text="Spice Level"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <TextView android:id="@+id/btnSpiceMild" android:layout_width="90dp" android:layout_height="44dp" android:layout_marginEnd="10dp" android:background="@drawable/bg_recommended_card" android:gravity="center" android:text="mild" android:textColor="#374151" android:textSize="13sp" android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btnSpiceMedium" android:layout_width="90dp" android:layout_height="44dp" android:layout_marginEnd="10dp" android:background="@drawable/bg_recommended_card" android:gravity="center" android:text="medium" android:textColor="#374151" android:textSize="13sp" android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btnSpiceHot" android:layout_width="90dp" android:layout_height="44dp" android:background="@drawable/bg_recommended_card" android:gravity="center" android:text="hot" android:textColor="#374151" android:textSize="13sp" android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- Allergies -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"
                android:text="Allergies"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_recommended_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Your allergies from diet plan:"
                    android:textColor="#888888"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:id="@+id/containerAllergies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </LinearLayout>

            <!-- Send button -->
            <TextView
                android:id="@+id/btnSendToKitchen"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/light_green_rectangle"
                android:gravity="center"
                android:text="Send My Plan to Kitchen"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
