<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ── TOP BAR ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="52dp"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="24dp"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/btnSchedulingBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_notif"
                    android:src="@drawable/button_arrow"
                    android:contentDescription="Back"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Meal Scheduling"
                    android:textColor="#171717"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drag meals to schedule your day"
                    android:textColor="#737373"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- ── DAILY CALORIES CARD ────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_streak_card"
                android:padding="16dp"
                android:orientation="vertical">

                <!-- Header -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="Daily Calories"
                        android:textColor="#525252"
                        android:textSize="12sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="↑ "
                            android:textColor="#FFCB65"
                            android:textSize="12sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Auto-adjusting"
                            android:textColor="#FFCB65"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </RelativeLayout>

                <!-- Calorie numbers -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvSchedulingCalEaten"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1570"
                        android:textColor="#111827"
                        android:textSize="28sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvSchedulingCalGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="/ 2000"
                        android:textColor="#6B7280"
                        android:textSize="16sp"/>
                </LinearLayout>

                <!-- Progress bar -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="8dp">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#E5E7EB"/>
                    <View
                        android:id="@+id/progressSchedulingCal"
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#FFCB65"/>
                </FrameLayout>
            </LinearLayout>

            <!-- ── MORNING SECTION ────────────────────── -->
            <TextView
                android:id="@+id/tvMorningSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="12dp"
                android:text="Morning"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/containerMorningMeals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- ── NOON SECTION ───────────────────────── -->
            <TextView
                android:id="@+id/tvNoonSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:text="Noon"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/containerNoonMeals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- ── NIGHT SECTION ──────────────────────── -->
            <TextView
                android:id="@+id/tvNightSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:text="Night"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/containerNightMeals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
