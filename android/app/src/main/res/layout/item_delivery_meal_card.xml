<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_highlight_card"
    android:elevation="3dp"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/imgDeliveryMeal"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/bg_image_placeholder"
        android:scaleType="centerCrop"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvDeliveryMealName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:textColor="#111827"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvDeliveryMealPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="#FFA157"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <!-- Macros row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:orientation="horizontal">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/tvDeliveryMealCal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#111827" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="kcal" android:textColor="#888888" android:textSize="10sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/tvDeliveryMealProtein" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#111827" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="protein" android:textColor="#888888" android:textSize="10sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/tvDeliveryMealCarbs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#111827" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="carbs" android:textColor="#888888" android:textSize="10sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/tvDeliveryMealFat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#111827" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="fats" android:textColor="#888888" android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Order Now button -->
        <TextView
            android:id="@+id/btnOrderNow"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/orange_rectangle"
            android:gravity="center"
            android:text="Order Now"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>
</LinearLayout>
