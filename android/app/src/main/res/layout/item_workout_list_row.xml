<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_recommended_card"
    android:orientation="vertical"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Image -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="140dp">

        <ImageView
            android:id="@+id/imgWorkoutListRow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#E5E7EB"/>

        <TextView
            android:id="@+id/tvWorkoutListRowPremium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="10dp"
            android:text="⭐ Premium"
            android:textColor="#92400E"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_time"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvWorkoutListRowName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#171717"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvWorkoutListRowDifficulty"
                android:textColor="#C3E66E"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView android:text="  ·  " android:textColor="#9CA3AF" android:textSize="12sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvWorkoutListRowDuration"
                android:textColor="#737373"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView android:text="  ·  " android:textColor="#9CA3AF" android:textSize="12sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvWorkoutListRowCal"
                android:textColor="#737373"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <android.widget.Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvWorkoutListRowExercises"
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
