<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Hero image with back button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="260dp">

                <ImageView
                    android:id="@+id/imgWorkoutDetailHero"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#E5E7EB"/>

                <ImageButton
                    android:id="@+id/btnWorkoutDetailBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="16dp"
                    android:src="@drawable/button_arrow"
                 />

                <TextView
                    android:id="@+id/tvWorkoutDetailPremium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="16dp"
                    android:text="⭐ Premium"
                    android:textColor="#92400E"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_time"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- Workout info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWorkoutDetailName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#171717"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvWorkoutDetailCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#737373"
                    android:textSize="13sp"
                    android:layout_marginBottom="16dp"/>

                <!-- Stats row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                        android:background="@drawable/bg_recommended_card" android:gravity="center"
                        android:orientation="horizontal" android:layout_marginEnd="8dp">
                        <TextView android:text="🕐 " android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvWorkoutDetailDuration" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                        android:background="@drawable/bg_recommended_card" android:gravity="center"
                        android:orientation="horizontal" android:layout_marginEnd="8dp">
                        <TextView android:text="🔥 " android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvWorkoutDetailCalories" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                        android:background="@drawable/bg_recommended_card" android:gravity="center"
                        android:orientation="horizontal">
                        <TextView android:text="⚡ " android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvWorkoutDetailDifficulty" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Equipment -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:text="Equipment" android:textColor="#171717" android:textSize="14sp"
                        android:textStyle="bold" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:id="@+id/tvEquipmentCount" android:textColor="#C3E66E" android:textSize="12sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:scrollbars="none" android:layout_marginBottom="20dp">
                    <LinearLayout android:id="@+id/containerWorkoutEquipment" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:orientation="horizontal"/>
                </HorizontalScrollView>

                <!-- Exercises header -->
                <TextView android:text="Exercises" android:textColor="#171717" android:textSize="14sp"
                    android:textStyle="bold" android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <LinearLayout
                    android:id="@+id/containerWorkoutExercises"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Custom Workout + Start Workout buttons -->
    <LinearLayout
        android:id="@+id/btnCustomWorkout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_recommended_card"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:text="⚙️  Custom Workout"
            android:textColor="#374151"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Start Workout button -->
    <LinearLayout
        android:id="@+id/btnStartWorkout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/light_green_rectangle"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:text="Start Workout"
            android:textColor="#4A6200"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</LinearLayout>
