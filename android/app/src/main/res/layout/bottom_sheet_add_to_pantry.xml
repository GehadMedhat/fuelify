<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_streak_card"
    android:orientation="vertical"
    android:paddingBottom="40dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="#D1D5DB"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="6dp">

        <TextView
            android:text="🥫"
            android:textSize="24sp"
            android:layout_marginEnd="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:text="Add to Pantry"
                android:textColor="#171717"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvPantryDialogName"
                android:textColor="#737373"
                android:textSize="13sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F3F4F6"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"/>

    <!-- Quantity row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:text="Quantity"
            android:textColor="#374151"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_recommended_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="4dp">

            <!-- Minus button -->
            <TextView
                android:id="@+id/btnQtyMinus"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="−"
                android:textSize="22sp"
                android:textColor="#374151"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:id="@+id/tvQtyValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="100"
                android:textSize="18sp"
                android:textColor="#171717"
                android:textStyle="bold"
                android:gravity="center"/>

            <!-- Plus button -->
            <TextView
                android:id="@+id/btnQtyPlus"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="+"
                android:textSize="22sp"
                android:textColor="#374151"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Expiry row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:text="Expires in (days)"
            android:textColor="#374151"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Quick select chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/chip3"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:text="3 days"
                android:textSize="12sp"
                android:textColor="#374151"
                android:gravity="center"
                android:background="@drawable/bg_recommended_card"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip7"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:text="7 days"
                android:textSize="12sp"
                android:textColor="#4A6200"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_badge_completed"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip14"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:text="14 days"
                android:textSize="12sp"
                android:textColor="#374151"
                android:gravity="center"
                android:background="@drawable/bg_recommended_card"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip30"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:text="30 days"
                android:textSize="12sp"
                android:textColor="#374151"
                android:gravity="center"
                android:background="@drawable/bg_recommended_card"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Custom days input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_recommended_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:text="📅  Custom:"
                android:textColor="#737373"
                android:textSize="13sp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etPantryDays"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="e.g. 21"
                android:inputType="number"
                android:background="@null"
                android:textColor="#171717"
                android:textColorHint="#9CA3AF"
                android:textSize="14sp"/>

            <TextView
                android:text="days"
                android:textColor="#737373"
                android:textSize="13sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Add button -->
    <LinearLayout
        android:id="@+id/btnConfirmAddPantry"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/bg_badge_completed"
        android:gravity="center"
        android:orientation="horizontal"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:text="✓  Add to Pantry"
            android:textColor="#4A6200"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</LinearLayout>
