<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_streak_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Meal image -->
    <ImageView
        android:id="@+id/imgSwitchMeal"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/bg_image_placeholder"
        android:scaleType="centerCrop"/>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSwitchMealName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:textColor="#111827"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvSwitchMealInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Arrow -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="›"
        android:textColor="#C3E66E"
        android:textSize="24sp"
        android:textStyle="bold"/>
</LinearLayout>
