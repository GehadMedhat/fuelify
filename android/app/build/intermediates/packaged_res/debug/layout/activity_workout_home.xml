<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:paddingHorizontal="20dp"
                android:paddingTop="52dp"
                android:paddingBottom="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvWorkoutGreeting"
                        android:text="Hi, there"
                        android:textColor="#171717"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Category button replacing the bell icon -->
                <TextView
                    android:id="@+id/tvCategoryViewAll"
                    android:textColor="#3A5C00"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/menu_button"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Search -->
            <LinearLayout
                android:id="@+id/layoutWorkoutSearch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_picker_selected"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/green_search"
                    android:textSize="16sp"/>
                <TextView android:text="Search something" android:textColor="#9CA3AF" android:textSize="14sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Today's Workout Progress card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_progress_card"
                android:padding="16dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:orientation="vertical">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="Today's Progress" android:textColor="#FFFFFF"
                            android:textSize="15sp" android:textStyle="bold"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvTodayWorkoutStatus" android:text="No workout yet"
                            android:textColor="#33000000" android:textSize="12sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvTodayWorkoutCalories" android:text=""
                        android:textColor="#C3E66E" android:textSize="14sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Progress bar for today -->
                <ProgressBar
                    android:id="@+id/progressTodayWorkout"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progressTint="#3A5C00"
                    android:progressBackgroundTint="#F9F4F1"
                    android:max="100"
                    android:progress="0"/>

                <!-- This week sessions -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvWeekWorkouts" android:text="0"
                            android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"
                            android:gravity="center"
                            android:layout_width="match_parent" android:layout_height="wrap_content"/>
                        <TextView android:text="Sessions" android:textColor="#33000000" android:textSize="11sp"
                            android:gravity="center"
                            android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <View android:layout_width="1dp" android:layout_height="40dp" android:background="#E5E7EB"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvWeekCalories" android:text="0"
                            android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"
                            android:gravity="center"
                            android:layout_width="match_parent" android:layout_height="wrap_content"/>
                        <TextView android:text="Kcal burned" android:textColor="#33000000" android:textSize="11sp"
                            android:gravity="center"
                            android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <View android:layout_width="1dp" android:layout_height="40dp" android:background="#E5E7EB"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvWeekMinutes" android:text="0"
                            android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"
                            android:gravity="center"
                            android:layout_width="match_parent" android:layout_height="wrap_content"/>
                        <TextView android:text="Minutes" android:textColor="#33000000" android:textSize="11sp"
                            android:gravity="center"
                            android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Weekly Schedule Calendar -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="#FFFFFF" android:padding="16dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:orientation="vertical">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView android:text="This Week" android:textColor="#171717"
                        android:textSize="14sp" android:textStyle="bold"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:id="@+id/tvWeekRange" android:text=""
                        android:textColor="#9CA3AF" android:textSize="11sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- 7 day cells -->
                <LinearLayout android:id="@+id/containerWeekCalendar"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </LinearLayout>

            <!-- Suggested header with personalized reason -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingHorizontal="20dp" android:layout_marginBottom="8dp"
                android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:text="Suggested For You" android:textColor="#171717"
                        android:textSize="15sp" android:textStyle="bold"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                </LinearLayout>
                <TextView android:id="@+id/tvSuggestedReason" android:text=""
                    android:textColor="#9CA3AF" android:textSize="11sp"
                    android:visibility="gone"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Suggested Workouts — horizontal scroll of 3 options -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:scrollbars="none"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:id="@+id/containerSuggestedWorkouts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <!-- Popular Workouts header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="Popular Workouts" android:textColor="#171717" android:textSize="15sp"
                        android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvWorkoutsCount" android:text="Workouts: 70" android:textColor="#737373"
                        android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <TextView android:id="@+id/tvWorkoutsViewAll" android:text="View All" android:textColor="#C3E66E"
                    android:textSize="13sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- Popular Workouts horizontal scroll -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:scrollbars="none"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:id="@+id/containerPopularWorkouts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <!-- Exercises header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="Exercises" android:textColor="#171717" android:textSize="15sp"
                        android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvExercisesCount" android:text="Exercises: 70" android:textColor="#737373"
                        android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <TextView android:id="@+id/tvExercisesViewAll" android:text="View All" android:textColor="#C3E66E"
                    android:textSize="13sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- Exercises list -->
            <LinearLayout
                android:id="@+id/containerExercises"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:orientation="vertical"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_nav"
        android:paddingHorizontal="8dp">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:padding="8dp">
            <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/home"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Home" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navWorkouts" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:padding="8dp">
            <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/green_workout"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Workouts" android:textColor="#C3E66E" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navDiet" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:padding="8dp">
            <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/gray_diet"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Diet" android:textColor="#AAAAAA" android:textSize="10sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navStats" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:padding="8dp">
            <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/stats"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Statistics" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:padding="8dp">
            <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/profile"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Profile" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>


    </LinearLayout>
</LinearLayout>