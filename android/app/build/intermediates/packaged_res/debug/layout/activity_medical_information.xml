<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="52dp"
                android:layout_marginBottom="4dp">
                <ImageButton
                    android:id="@+id/btnMedicalBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/button_arrow"
                    android:layout_marginEnd="12dp"/>>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="Medical Information" android:textColor="#000000" android:textSize="20sp"
                        android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Help us personalize your nutrition and workout plan"
                        android:textColor="#737373" android:textSize="12sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Medical Conditions Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_recommended_card"
                android:padding="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"
                android:orientation="vertical">

                <TextView android:text="Medical Conditions" android:textColor="#000000" android:textSize="16sp"
                    android:textStyle="bold" android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <LinearLayout
                    android:id="@+id/containerConditions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

            <!-- Allergies -->
            <TextView android:text="Allergies" android:textColor="#000000" android:textSize="16sp"
                android:textStyle="bold" android:layout_marginBottom="12dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <!-- Selected chips -->
            <LinearLayout
                android:id="@+id/containerAllergyChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp"/>

            <!-- Choose from list button -->
            <LinearLayout
                android:id="@+id/btnAddAllergy"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_recommended_card"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">
                <TextView android:text="🌿" android:textSize="18sp"
                    android:layout_marginEnd="10dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="Choose Allergies" android:textColor="#000000"
                        android:textSize="14sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Select from common allergens" android:textColor="#9CA3AF"
                        android:textSize="11sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <TextView android:text="›" android:textColor="#9CA3AF" android:textSize="22sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Current Medications -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_recommended_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp"
                android:orientation="vertical">

                <TextView android:text="Current Medications" android:textColor="#000000" android:textSize="16sp"
                    android:textStyle="bold" android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <LinearLayout
                    android:id="@+id/containerMedications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:id="@+id/btnAddMedication"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_recommended_card"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:text="+" android:textColor="#374151" android:textSize="18sp"
                        android:layout_marginEnd="6dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Add medication" android:textColor="#374151" android:textSize="14sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>



        </LinearLayout>
    </ScrollView>

    <!-- Save button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="20dp">
        <LinearLayout
            android:id="@+id/btnSaveMedical"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/orange_rectangle"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:text="Save Medical Information"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
