<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingVertical="23dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="26dp">

                <ImageButton
                    android:id="@+id/btnSummaryBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/button_arrow"
                    />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Summary"
                    android:textColor="#000000"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <TextView
                    android:text="⬆"
                    android:textColor="#374151"
                    android:textSize="20sp"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Section: Workout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:orientation="vertical">

                <TextView
                    android:text="Workout"
                    android:textColor="#000000"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Workout row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_recommended_card"
                    android:gravity="center_vertical"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imgSummaryWorkout"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:scaleType="centerCrop"
                        android:background="#E5E7EB"
                        android:layout_marginEnd="14dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvSummaryWorkoutName"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvSummaryExercises"
                                android:textColor="#C3E66E"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:layout_marginEnd="8dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:id="@+id/tvSummaryTimeRange"
                                android:textColor="#6B7280"
                                android:textSize="11sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Stats grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_recommended_card"
                    android:padding="20dp"
                    android:layout_marginBottom="24dp"
                    android:orientation="vertical">

                    <!-- Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <!-- Total time -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                                <TextView android:id="@+id/tvSummaryTotalTime" android:text="00:00:00"
                                    android:textColor="#000000" android:textSize="24sp" android:textStyle="bold"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>
                            <TextView android:text="Total time" android:textColor="#6B7280" android:textSize="12sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <!-- Avg Heart Rate -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                                <TextView android:id="@+id/tvSummaryAvgHR" android:text="164"
                                    android:textColor="#000000" android:textSize="24sp" android:textStyle="bold"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text=" bpm" android:textColor="#6B7280" android:textSize="12sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>
                            <TextView android:text="Avg Heart Rate" android:textColor="#6B7280" android:textSize="12sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Active Calories -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                                <TextView android:id="@+id/tvSummaryActiveCal" android:text="617"
                                    android:textColor="#000000" android:textSize="24sp" android:textStyle="bold"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text=" Kcal" android:textColor="#6B7280" android:textSize="12sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>
                            <TextView android:text="Active Calories" android:textColor="#6B7280" android:textSize="12sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <!-- Total Calories -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                                <TextView android:id="@+id/tvSummaryTotalCal" android:text="640"
                                    android:textColor="#000000" android:textSize="24sp" android:textStyle="bold"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text=" Kcal" android:textColor="#6B7280" android:textSize="12sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>
                            <TextView android:text="Total Calories" android:textColor="#6B7280" android:textSize="12sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Save button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/btnSaveWorkout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/light_green_rectangle"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:text="Save Workout"
                android:textColor="#4A6200"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
