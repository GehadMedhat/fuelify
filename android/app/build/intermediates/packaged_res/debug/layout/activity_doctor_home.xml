<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F9FAFB" android:orientation="vertical">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#FFFFFF" android:paddingHorizontal="20dp"
        android:paddingTop="48dp" android:paddingBottom="16dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:elevation="4dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:text="Fuelify Doctor" android:textColor="#F97316"
                android:textSize="12sp" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvDoctorName" android:textColor="#000000"
                android:textSize="20sp" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvDoctorSpecialty" android:textColor="#737373"
                android:textSize="12sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Wallet button -->
        <LinearLayout android:id="@+id/btnWallet" android:layout_width="48dp"
            android:layout_height="48dp" android:background="@drawable/bg_badge_time"
            android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:text="💰" android:textSize="22sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Stats bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#FFFFFF" android:paddingHorizontal="20dp"
        android:paddingVertical="12dp" android:orientation="horizontal"
        android:layout_marginBottom="1dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/tvStatTotal" android:text="0"
                android:textColor="#000000" android:textSize="20sp" android:textStyle="bold"
                android:gravity="center"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:text="Total" android:textColor="#9CA3AF" android:textSize="11sp"
                android:gravity="center"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>
        <View android:layout_width="1dp" android:layout_height="40dp" android:background="#E5E7EB"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/tvStatPending" android:text="0"
                android:textColor="#F97316" android:textSize="20sp" android:textStyle="bold"
                android:gravity="center"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:text="Pending" android:textColor="#9CA3AF" android:textSize="11sp"
                android:gravity="center"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>
        <View android:layout_width="1dp" android:layout_height="40dp" android:background="#E5E7EB"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/tvStatResponded" android:text="0"
                android:textColor="#22C55E" android:textSize="20sp" android:textStyle="bold"
                android:gravity="center"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:text="Responded" android:textColor="#9CA3AF" android:textSize="11sp"
                android:gravity="center"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Filter tabs + refresh -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#FFFFFF" android:paddingHorizontal="16dp"
        android:paddingVertical="10dp" android:orientation="horizontal"
        android:gravity="center_vertical" android:layout_marginBottom="8dp">

        <TextView android:id="@+id/btnFilterAll" android:text="All"
            android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"
            android:background="#F97316" android:paddingHorizontal="14dp"
            android:paddingVertical="6dp" android:layout_marginEnd="6dp"
            android:clickable="true" android:focusable="true"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/btnFilterPending" android:text="Needs Response"
            android:textColor="#374151" android:textSize="12sp" android:textStyle="bold"
            android:background="#E5E7EB" android:paddingHorizontal="14dp"
            android:paddingVertical="6dp" android:layout_marginEnd="6dp"
            android:clickable="true" android:focusable="true"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/btnFilterResponded" android:text="Done"
            android:textColor="#374151" android:textSize="12sp" android:textStyle="bold"
            android:background="#E5E7EB" android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:clickable="true" android:focusable="true"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <LinearLayout android:id="@+id/btnRefreshInbox" android:layout_width="36dp"
            android:layout_height="36dp" android:background="@drawable/bg_recommended_card"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:text="↻" android:textSize="18sp" android:textColor="#374151"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Cases list -->
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <TextView android:id="@+id/tvInboxEmpty"
                android:text="No cases yet" android:textColor="#9CA3AF"
                android:textSize="14sp" android:gravity="center"
                android:paddingTop="60dp" android:visibility="gone"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>

            <LinearLayout android:id="@+id/containerInbox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
