<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_recommended_card"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:layout_marginBottom="10dp">

    <!-- Product image (square thumbnail) -->
    <ImageView
        android:id="@+id/imgIngredientList"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_image_placeholder"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvIngredientListEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥩"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/tvIngredientListName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#171717"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvAllergenBadgeList"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠ Allergen"
                android:textColor="#92400E"
                android:textSize="9sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_time"
                android:paddingHorizontal="7dp"
                android:paddingVertical="4dp"
                android:visibility="gone"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvIngredientListSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#737373"
            android:textSize="11sp"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tvIngredientListMacros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F97316"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="8dp">

        <LinearLayout
            android:id="@+id/btnAddToPantryList"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_recommended_card"
            android:paddingVertical="7dp"
            android:gravity="center"
            android:layout_marginBottom="6dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:text="+ Pantry"
                android:textColor="#404040"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnAddToListList"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_completed"
            android:paddingVertical="7dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:text="+ List"
                android:textColor="#4A6200"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
